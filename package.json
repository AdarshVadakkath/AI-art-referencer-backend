    "express": "^5.2.1",
    "imagekit": "^6.0.0",
    "multer": "^2.1.1",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
